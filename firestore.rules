rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidCertification(data) {
      return data.title is string && data.title.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 500 &&
             (!data.keys().hasAll(['externalUrl']) || (data.externalUrl is string && data.externalUrl.size() <= 500));
    }

    function isVaibhav() {
      return isSignedIn() && (request.auth.token.email == 'vaishnavii0302@gmail.com' || request.auth.token.email == 'vaibhavchaurasiya@gmail.com');
    }

    // Certifications collection rules
    match /certifications/{certId} {
      allow read: if true;
      allow create: if isVaibhav() && isValidCertification(request.resource.data);
      allow update: if isVaibhav() && isValidCertification(request.resource.data);
      allow delete: if isVaibhav();
    }
  }
}
